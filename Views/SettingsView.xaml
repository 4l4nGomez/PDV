<UserControl x:Class="BakeryPOS.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Background="#F3F4F6" Margin="0">
        <StackPanel Margin="30">
            <TextBlock Text="Configuración del Sistema" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" Foreground="#1F2937"/>
            
            <Border Background="White" CornerRadius="10" Padding="30" BorderBrush="#E5E7EB" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="IMPRESORA DE TICKETS" FontSize="16" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,10"/>
                    <TextBlock Text="Seleccione la impresora térmica que utilizará el sistema para generar los comprobantes de venta." Foreground="#6B7280" Margin="0,0,0,20"/>

                    <Grid Margin="0,0,0,30">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="Dispositivos Disponibles:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <ComboBox ItemsSource="{Binding AvailablePrinters}" 
                                      SelectedItem="{Binding SelectedPrinter}"
                                      Height="45" VerticalContentAlignment="Center" FontSize="16"/>
                        </StackPanel>
                        
                        <Button Grid.Column="1" Content="Guardar Configuración" 
                                Command="{Binding SaveSettingsCommand}"
                                VerticalAlignment="Bottom" Height="45" Padding="30,0"
                                Background="#10B981" Foreground="White" FontWeight="Bold" BorderThickness="0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                    
                    <Separator Margin="0,0,0,20"/>
                    
                    <TextBlock Text="NOTAS DE INSTALACIÓN" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,10"/>
                    <TextBlock Text="• Asegúrese de que la impresora esté instalada y reconocida por Windows." Foreground="#6B7280" Margin="5,0,0,5"/>
                    <TextBlock Text="• Si instala el sistema en una máquina nueva, deberá venir a esta sección para vincular la impresora local." Foreground="#6B7280" Margin="5,0,0,5"/>
                    <TextBlock Text="• El sistema utiliza un formato de 80mm/58mm dependiendo del hardware." Foreground="#6B7280" Margin="5,0,0,5"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
