<UserControl x:Class="BakeryPOS.Views.PosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BakeryPOS.Views"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="1100">
    
    <UserControl.InputBindings>
        <KeyBinding Key="F1" Command="{Binding CheckoutAndPrintCommand}"/>
        <KeyBinding Key="F2" Command="{Binding CheckoutCommand}"/>
        <KeyBinding Key="F3" Command="{Binding FocusSearchCommand}"/>
    </UserControl.InputBindings>

    <Grid Background="{StaticResource BgBrush}">
        <Grid.ColumnDefinitions>
            <!-- ÁREA DE PRODUCTOS: Flexible (*) -->
            <ColumnDefinition Width="1.6*"/>
            <!-- CARRITO: Proporcional con límites profesionales -->
            <ColumnDefinition Width="1*" MinWidth="420" MaxWidth="650"/>
        </Grid.ColumnDefinitions>

        <!-- LADO IZQUIERDO: CATÁLOGO -->
        <Grid Grid.Column="0" Margin="25,25,12,25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Buscador -->
                <RowDefinition Height="*"/>    <!-- Productos -->
            </Grid.RowDefinitions>

            <!-- Buscador Estilo Comercial (Ancho Completo) -->
            <Border Grid.Row="0" Style="{StaticResource ModernCard}" Padding="15" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Text="🔍" VerticalAlignment="Center" Margin="10,0,15,0" FontSize="20"/>
                    
                    <Grid Grid.Column="1">
                        <TextBlock Text="Busca por nombre o escanea código [F3]..." 
                                   VerticalAlignment="Center" FontSize="18" Foreground="#94A3B8"
                                   IsHitTestVisible="False" Margin="5,0,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding SearchText}" Value=""/>
                                                <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=SearchBox}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        
                        <TextBox x:Name="SearchBox" 
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                 FontSize="18" BorderThickness="0" Background="Transparent">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding AddByCodeOrSearchCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                    </Grid>
                </Grid>
            </Border>

            <!-- Catálogo de Productos Flexible -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Focusable="False">
                <ItemsControl ItemsSource="{Binding FilteredProducts}" Focusable="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel HorizontalAlignment="Left" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                    CommandParameter="{Binding}" Background="Transparent" Padding="0" Margin="0,0,15,15">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="card" Style="{StaticResource ModernCard}" Padding="12" Width="175" Height="135">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <StackPanel Grid.Row="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15" HorizontalAlignment="Center" 
                                                             TextAlignment="Center" TextWrapping="Wrap" MaxHeight="45" Foreground="{StaticResource SecondaryBrush}"/>
                                                    <TextBlock Text="{Binding Price, StringFormat=C}" FontWeight="Black" FontSize="22" 
                                                             Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                                </StackPanel>
                                                <TextBlock Grid.Row="1" Text="{Binding Stock, StringFormat='{}Stock: {0}'}" FontSize="11" 
                                                         Foreground="{StaticResource TextSecBrush}" HorizontalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="card" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                <Setter TargetName="card" Property="Background" Value="#F5F3FF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- LADO DERECHO: RESUMEN DE VENTA (CARRITO) -->
        <Border Grid.Column="1" Style="{StaticResource ModernCard}" Margin="0,25,25,25" Padding="0" Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Cabecera -->
                    <RowDefinition Height="*"/>    <!-- Lista -->
                    <RowDefinition Height="Auto"/> <!-- Pie con Totales -->
                </Grid.RowDefinitions>

                <Border Background="{StaticResource PrimaryBrush}" Padding="15" CornerRadius="12,12,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🛒" FontSize="20" Margin="0,0,10,0"/>
                        <TextBlock Text="Resumen de Venta" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Detalle de Venta -->
                <DataGrid Grid.Row="1" ItemsSource="{Binding CurrentTicket}" AutoGenerateColumns="False" 
                          CanUserAddRows="False" IsReadOnly="True" GridLinesVisibility="None" 
                          BorderThickness="0" Background="Transparent" Margin="5"
                          RowHeight="65" AlternationCount="2">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{StaticResource TextSecBrush}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="10,5"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="DETALLE" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center" Margin="5,0">
                                        <TextBlock Text="{Binding Product.Name}" FontWeight="Bold" FontSize="16" Foreground="{StaticResource SecondaryBrush}" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding UnitPrice, StringFormat=C}" FontSize="12" Foreground="{StaticResource TextSecBrush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <DataGridTemplateColumn Header="CANT" Width="85">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="25"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="25"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Command="{Binding DataContext.DecrementQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}" Content="−" Background="#F1F5F9" Foreground="{StaticResource DangerBrush}" BorderThickness="0" Height="25"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Quantity}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Black" FontSize="14"/>
                                        <Button Grid.Column="2" Command="{Binding DataContext.IncrementQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}" Content="+" Background="#F1F5F9" Foreground="{StaticResource AccentBrush}" BorderThickness="0" Height="25"/>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="TOTAL" Width="95">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SubTotal, StringFormat=C}" FontWeight="Black" FontSize="15" 
                                               Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <DataGridTemplateColumn Width="45">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.RemoveFromCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                            CommandParameter="{Binding}" 
                                            Background="#FFF1F2" Foreground="{StaticResource DangerBrush}" 
                                            Width="32" Height="32" HorizontalAlignment="Center"
                                            BorderThickness="1" BorderBrush="#FECACA">
                                        <TextBlock Text="×" FontSize="18" FontWeight="Bold" Margin="0,-2,0,0"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Pie de Carrito con Totales y Cobro -->
                <Border Grid.Row="2" Background="#1E293B" Padding="20" CornerRadius="0,0,12,12">
                    <StackPanel>
                        <Grid Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="TOTAL A PAGAR" FontSize="13" FontWeight="Bold" Foreground="#94A3B8"/>
                                <TextBlock Text="Sujeto a descuentos" FontSize="11" Foreground="#64748B"/>
                            </StackPanel>
                            <TextBlock Text="{Binding TicketTotal, StringFormat=C}" FontSize="40" FontWeight="Black" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                        
                        <UniformGrid Columns="2" Height="80">
                            <Button Command="{Binding CheckoutCommand}" Background="{StaticResource SecondaryBrush}" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="SOLO COBRAR" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="[F2]" FontSize="12" Opacity="0.7" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <Button Command="{Binding CheckoutAndPrintCommand}" Background="{StaticResource AccentBrush}" Margin="6,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="COBRAR+TICKET" FontSize="14" FontWeight="Black" HorizontalAlignment="Center"/>
                                    <TextBlock Text="[F1]" FontSize="12" Opacity="0.8" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- DIALOGO DE DESCUENTO (OVERLAY) -->
        <Border Grid.ColumnSpan="2" Background="#CC000000" Panel.ZIndex="100"
                Visibility="{Binding IsDiscountDialogVisible, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
            <Border Style="{StaticResource ModernCard}" Width="380" VerticalAlignment="Center" Padding="35" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="🏷️ Aplicar Descuento" FontSize="24" FontWeight="Bold" Margin="0,0,0,25" HorizontalAlignment="Center"/>
                    
                    <TextBlock Text="Precio Unitario Personalizado:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding ProposedPrice, UpdateSourceTrigger=PropertyChanged}" FontSize="22" Padding="12" Margin="0,0,0,20"/>

                    <TextBlock Text="PIN de Administrador:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <PasswordBox x:Name="AdminPinBox" Height="50" FontSize="22" Margin="0,0,0,30"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Button Content="CANCELAR" Command="{Binding CloseDiscountDialogCommand}" 
                                Background="#E2E8F0" Foreground="{StaticResource SecondaryBrush}" Height="50" Margin="0,0,10,0"/>
                        <Button Grid.Column="1" Content="APLICAR" Click="ApplyDiscount_Click" 
                                Background="{StaticResource PrimaryBrush}" Height="50" Margin="10,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>