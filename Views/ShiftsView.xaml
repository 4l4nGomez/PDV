<UserControl x:Class="BakeryPOS.Views.ShiftsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BakeryPOS"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">
    <UserControl.InputBindings>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveAuditCommand}"/>
        <KeyBinding Key="Add" Command="{Binding IncreaseAuditCommand}"/>
        <KeyBinding Key="Subtract" Command="{Binding DecreaseAuditCommand}"/>
    </UserControl.InputBindings>

    <UserControl.Resources>
        <Style x:Key="AuditCellStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:DifferenceToBrushConverter x:Key="DiffBrushConverter"/>
        
        <Style x:Key="CenterHeader" TargetType="DataGridColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </UserControl.Resources>
    <Grid>
        <!-- Panel de Apertura -->
        <Grid Visibility="{Binding IsOpenShiftVisible, Converter={StaticResource BoolToVis}}" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border Background="White" Padding="30" Width="400" CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="Apertura de Caja" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="Dinero inicial en cajón:" FontSize="16" Margin="0,0,0,10" Foreground="#374151"/>
                    <TextBox Text="{Binding StartingCash}" FontSize="24" Height="45" Padding="5" Margin="0,0,0,25" VerticalContentAlignment="Center"/>
                    
                    <Button Content="ABRIR TURNO" Command="{Binding OpenShiftCommand}" Height="55" Background="#10B981" Foreground="White" FontSize="18" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Panel de Cierre -->
        <Grid Visibility="{Binding IsCloseShiftVisible, Converter={StaticResource BoolToVis}}" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <TabControl x:Name="MainTabControl" Grid.Row="0" BorderThickness="0" Background="Transparent" 
                        SelectedIndex="{Binding SelectedTabIndex}"
                        SelectionChanged="MainTabControl_SelectionChanged">
                <TabItem Header="Corte de Efectivo" FontSize="16" Padding="15,5">
                    <Grid Background="White" Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Arqueo de Caja" FontSize="22" FontWeight="Bold" Foreground="#1F2937" Margin="15,15,0,15"/>

                        <!-- Tarjetas de Métricas -->
                        <UniformGrid Grid.Row="1" Columns="4" Margin="10,0,10,20">
                            <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="15" Margin="5">
                                <StackPanel>
                                    <TextBlock Text="Ventas registradas" FontSize="12" Foreground="#6B7280" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding TotalSalesAmount, StringFormat=C}" FontSize="24" FontWeight="Bold" Foreground="#1F2937" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1" CornerRadius="8" Padding="15" Margin="5">
                                <StackPanel>
                                    <TextBlock Text="Ingresos (+)" FontSize="12" Foreground="#059669" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding TotalInflows, StringFormat=C}" FontSize="24" FontWeight="Bold" Foreground="#10B981" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="8" Padding="15" Margin="5">
                                <StackPanel>
                                    <TextBlock Text="Gastos / Retiros (-)" FontSize="12" Foreground="#991B1B" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding TotalExpenses, StringFormat=C}" FontSize="24" FontWeight="Bold" Foreground="#DC2626" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="8" Padding="15" Margin="5">
                                <StackPanel>
                                    <TextBlock Text="EFECTIVO ESPERADO" FontSize="12" Foreground="#2563EB" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding ExpectedCash, StringFormat=C}" FontSize="24" FontWeight="Bold" Foreground="#3B82F6" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Grid Grid.Row="2" Margin="15,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="#F3F4F6" BorderBrush="#E5E7EB" BorderThickness="1" Padding="20" Margin="0,0,10,0" CornerRadius="8" VerticalAlignment="Top">
                                <StackPanel>
                                    <TextBlock Text="Registrar Movimiento" FontSize="16" FontWeight="Bold" Foreground="#374151" Margin="0,0,0,15"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,10,0">
                                            <TextBlock Text="Monto:" FontSize="12" Foreground="#6B7280" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding MovementAmountText, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="5" VerticalContentAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Concepto:" FontSize="12" Foreground="#6B7280" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding MovementDescription, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="5" VerticalContentAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                    <UniformGrid Columns="2" Margin="0,15,0,0">
                                        <Button Content="+ Entrada" Command="{Binding AddMovementCommand}" CommandParameter="IN" Background="#10B981" Foreground="White" Height="40" Margin="0,0,5,0" BorderThickness="0" FontWeight="Bold"/>
                                        <Button Content="- Salida" Command="{Binding AddMovementCommand}" CommandParameter="OUT" Background="#EF4444" Foreground="White" Height="40" Margin="5,0,0,0" BorderThickness="0" FontWeight="Bold"/>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Background="White" BorderBrush="#3B82F6" BorderThickness="2" Padding="20" Margin="10,0,0,0" CornerRadius="8" VerticalAlignment="Top">
                                <StackPanel>
                                    <TextBlock Text="Cierre de Caja" FontSize="16" FontWeight="Bold" Foreground="#1E40AF" Margin="0,0,0,15"/>
                                    <TextBlock Text="Dinero real en cajón:" FontSize="12" Foreground="#6B7280" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding ActualCashText, UpdateSourceTrigger=PropertyChanged}" FontSize="32" FontWeight="Bold" Height="55" Padding="5" BorderThickness="1" BorderBrush="#BFDBFE" TextAlignment="Center" Margin="0,0,0,15"/>
                                    
                                    <Grid Margin="0,0,0,15">
                                        <TextBlock Text="Diferencia:" FontSize="16" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding CashDifference, StringFormat=C}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Right" Foreground="{Binding CashDifference, Converter={StaticResource DiffBrushConverter}}"/>
                                    </Grid>
                                    
                                    <Button Content="REALIZAR CORTE" Command="{Binding CloseShiftCommand}" Height="50" Background="#3B82F6" Foreground="White" FontSize="18" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>
                
                <TabItem Header="Auditoría de Pan" FontSize="16" Padding="15,5">
                    <Grid Background="White" Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Conteo Físico de Inventario" FontSize="22" FontWeight="Bold" Foreground="#1F2937" Margin="15,15,0,15"/>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="15,0,15,20"> 
                            <Button Command="{Binding SaveAuditCommand}" Height="45" Padding="20,5" Background="#10B981" Foreground="White" BorderThickness="0" Margin="0,0,10,0" FontWeight="Bold">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <ContentPresenter.Content>
                                                    <TextBlock Text="Guardar Auditoría (Ctrl+S)" FontWeight="Bold"/>
                                                </ContentPresenter.Content>
                                            </ContentPresenter>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Command="{Binding SyncAllTheoreticalCommand}" Height="45" Padding="15,5" Background="#F1F5F9" Foreground="#475569" BorderThickness="1" BorderBrush="#CBD5E1" Margin="0,0,20,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <ContentPresenter.Content>
                                                    <TextBlock Text="Igualar al Teórico (Todo)"/>
                                                </ContentPresenter.Content>
                                            </ContentPresenter>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            
                            <Border Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,10,0" MinWidth="180">
                                <StackPanel>
                                    <TextBlock Text="PIEZAS FALTANTES" FontSize="11" Foreground="#991B1B" FontWeight="Bold" Opacity="0.8"/>
                                    <TextBlock Text="{Binding TotalItemsMissing}" FontSize="26" FontWeight="Black" Foreground="#DC2626"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="15" MinWidth="200">
                                <StackPanel>
                                    <TextBlock Text="MÉRDA TOTAL EN PESOS" FontSize="11" Foreground="#374151" FontWeight="Bold" Opacity="0.8"/>
                                    <TextBlock Text="{Binding FinancialLoss, StringFormat=C}" FontSize="26" FontWeight="Black" Foreground="#1F2937"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <DataGrid x:Name="AuditDataGrid" Grid.Row="2" ItemsSource="{Binding InventoryAudit}" AutoGenerateColumns="False" 
                                  CanUserAddRows="False" GridLinesVisibility="None" RowBackground="White" 
                                  Margin="15,0,15,15" BorderThickness="1" BorderBrush="#E5E7EB" 
                                  SelectedItem="{Binding SelectedAuditItem, Mode=TwoWay}" 
                                  SelectionMode="Single" SelectionUnit="FullRow"
                                  AlternationCount="2" RowHeight="45"
                                  PreviewKeyDown="AuditDataGrid_PreviewKeyDown">
                            <DataGrid.Resources>
                                <!-- Estilo para mejorar el contraste al seleccionar filas -->
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3B82F6"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#E2E8F0"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#1E293B"/>

                                <Style TargetType="DataGridRow">
                                    <Setter Property="FontSize" Value="14"/>
                                    <Style.Triggers>
                                        <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                            <Setter Property="Background" Value="#F8FAFC"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding Difference}" Value="0">
                                            <Setter Property="Opacity" Value="0.8"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Difference, Converter={StaticResource DiffBrushConverter}}" Value="#DC2626">
                                            <Setter Property="Background" Value="#FFF1F2"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="NOMBRE DEL PRODUCTO" Binding="{Binding Name}" Width="*" IsReadOnly="True" FontWeight="Bold">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Margin" Value="15,0"/>
                                            <Setter Property="FontSize" Value="15"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <DataGridTextColumn Header="STOCK TEÓRICO" Binding="{Binding TheoreticalStock}" Width="130" IsReadOnly="True" HeaderStyle="{StaticResource CenterHeader}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="FontSize" Value="15"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="#1E293B"/> <!-- Color oscuro para máximo contraste -->
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <DataGridTemplateColumn Header="CONTEO REAL" Width="150" HeaderStyle="{StaticResource CenterHeader}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border BorderThickness="1" BorderBrush="#CBD5E1" CornerRadius="6" Background="White" Margin="10,4">
                                                <TextBox Text="{Binding PhysicalStock, UpdateSourceTrigger=PropertyChanged}" 
                                                         TextAlignment="Center" FontWeight="Black" FontSize="18" 
                                                         BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center"
                                                         Foreground="#1E293B"/> <!-- Color oscuro fijo para que siempre sea visible sobre el fondo blanco -->
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="DIFERENCIA" Binding="{Binding Difference}" Width="120" IsReadOnly="True" HeaderStyle="{StaticResource CenterHeader}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Black"/>
                                            <Setter Property="FontSize" Value="16"/>
                                            <Setter Property="Foreground" Value="{Binding Difference, Converter={StaticResource DiffBrushConverter}}"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="VALOR DE PÉRDIDA" Binding="{Binding FinancialImpact, StringFormat=C}" Width="150" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Black"/>
                                            <Setter Property="FontSize" Value="16"/>
                                            <Setter Property="Foreground" Value="{Binding FinancialImpact, Converter={StaticResource DiffBrushConverter}}"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Margin" Value="0,0,20,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</UserControl>
