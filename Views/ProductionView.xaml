<UserControl x:Class="BakeryPOS.Views.ProductionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100"
             Padding="20">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Control de Producción y Mermas" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" Foreground="#1F2937"/>

        <Grid Grid.Row="1" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Card: Producción (Entradas) -->
            <Border Grid.Column="0" Background="White" CornerRadius="10" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,10,0" Padding="20">
                <StackPanel>
                    <Border Background="#D1FAE5" HorizontalAlignment="Left" CornerRadius="5" Padding="10,5" Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🍞" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="ENTRADA DE PAN (HORNEADO)" Foreground="#065F46" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Código:" Margin="0,0,0,5" Foreground="#6B7280" FontSize="11" FontWeight="Bold"/>
                            <TextBox x:Name="ProductionCodeInput" Text="{Binding ProductionSearchCode, UpdateSourceTrigger=PropertyChanged}" Height="40" VerticalContentAlignment="Center" Padding="8,0" FontSize="16" FontWeight="Bold" BorderBrush="#10B981"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Nombre del Pan:" Margin="0,0,0,5" Foreground="#6B7280" FontSize="11" FontWeight="Bold"/>
                            <ComboBox ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}" DisplayMemberPath="Name" Height="40" VerticalContentAlignment="Center" Background="#F9FAFB"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Cantidad Horneada (Piezas):" Margin="0,0,0,5" Foreground="#374151" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding QuantityProduced, UpdateSourceTrigger=PropertyChanged}" Height="45" Margin="0,0,0,20" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Padding="5,0" FontSize="24" FontWeight="Black" BorderBrush="#10B981" BorderThickness="2"/>

                    <Button x:Name="BtnRegisterProduction" Content="REGISTRAR ENTRADA [Enter]" Command="{Binding RegisterProductionCommand}" Click="BtnRegisterProduction_Click" IsDefault="True" Height="50" Background="#10B981" Foreground="White" FontWeight="Bold" FontSize="16" BorderThickness="0" Cursor="Hand">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Card: Merma (Salidas) -->
            <Border Grid.Column="1" Background="White" CornerRadius="10" BorderBrush="#E5E7EB" BorderThickness="1" Margin="10,0,0,0" Padding="20">
                <StackPanel>
                    <Border Background="#FEE2E2" HorizontalAlignment="Left" CornerRadius="5" Padding="10,5" Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🗑️" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="SALIDA POR MERMA (DAÑOS)" Foreground="#991B1B" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Código:" Margin="0,0,0,5" Foreground="#6B7280" FontSize="11" FontWeight="Bold"/>
                            <TextBox x:Name="ShrinkageCodeInput" Text="{Binding ShrinkageSearchCode, UpdateSourceTrigger=PropertyChanged}" Height="40" VerticalContentAlignment="Center" Padding="8,0" FontSize="16" FontWeight="Bold" BorderBrush="#EF4444"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Nombre del Pan:" Margin="0,0,0,5" Foreground="#6B7280" FontSize="11" FontWeight="Bold"/>
                            <ComboBox ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedShrinkageProduct}" DisplayMemberPath="Name" Height="40" VerticalContentAlignment="Center" Background="#F9FAFB"/>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Cantidad:" Margin="0,0,0,5" Foreground="#374151" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding ShrinkageQuantity, UpdateSourceTrigger=PropertyChanged}" Height="45" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Padding="5,0" FontSize="24" FontWeight="Black" BorderBrush="#EF4444" BorderThickness="2"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Motivo de la merma:" Margin="0,0,0,5" Foreground="#374151" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding ShrinkageReason}" Height="45" VerticalContentAlignment="Center" Padding="10,0" FontSize="14" BorderBrush="#D1D5DB"/>
                        </StackPanel>
                    </Grid>

                    <Button x:Name="BtnRegisterShrinkage" Content="REGISTRAR MERMA [Enter]" Command="{Binding RegisterShrinkageCommand}" Click="BtnRegisterShrinkage_Click" Height="50" Margin="0,20,0,0" Background="#EF4444" Foreground="White" FontWeight="Bold" FontSize="16" BorderThickness="0" Cursor="Hand">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Inventory Preview -->
        <Border Grid.Row="2" Background="White" CornerRadius="10" BorderBrush="#E5E7EB" BorderThickness="1" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Resumen de Inventario (Mostrador)" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" Foreground="#1F2937"/>
                <DataGrid Grid.Row="1" ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" GridLinesVisibility="None" BorderThickness="0" RowBackground="White" Cursor="Hand">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Código" Binding="{Binding Code}" Width="100"/>
                        <DataGridTextColumn Header="Nombre del Producto" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Categoría" Binding="{Binding Category}" Width="150"/>
                        <DataGridTemplateColumn Header="Horneado" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#D1FAE5" CornerRadius="5" Padding="10,5" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding TotalProduced}" FontWeight="Bold" Foreground="#065F46"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Merma" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#FEE2E2" CornerRadius="5" Padding="10,5" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding TotalShrinkage}" FontWeight="Bold" Foreground="#991B1B"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Existencias" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#F3F4F6" CornerRadius="5" Padding="10,5" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding Stock}" FontWeight="Bold" Foreground="#1F2937"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Flash Notification Overlay (Floats over all content) -->
        <Border Grid.RowSpan="3" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,15,0,0" 
                Padding="25,12" CornerRadius="25" Background="#EE1F2937" IsHitTestVisible="False">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.3"/>
            </Border.Effect>
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Opacity" Value="0"/>
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="0.8" ScaleY="0.8" CenterX="100" CenterY="25"/>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsNotificationVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Setter Property="Opacity" Value="1"/>
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.8" To="1" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.8" To="1" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="10" Height="10" Fill="{Binding StatusColor}" Margin="0,0,15,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontWeight="Bold" FontSize="15" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>