<Window x:Class="BakeryPOS.Views.TicketView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vista Previa del Ticket" Width="260" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" Background="#F1F5F9"
        WindowStyle="None" AllowsTransparency="True" BorderThickness="1" BorderBrush="#CBD5E1">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Titulo -->
            <RowDefinition Height="Auto"/> <!-- Ticket -->
            <RowDefinition Height="Auto"/> <!-- Boton -->
        </Grid.RowDefinitions>

        <TextBlock Text="PREVISUALIZACIÓN DE TICKET" FontSize="10" FontWeight="Black" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <!-- EL TICKET REAL -->
        <Border Grid.Row="1" x:Name="TicketBorder" Background="White" Width="200" Padding="12" CornerRadius="0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            <StackPanel>
                <!-- CABECERA -->
                <TextBlock Text="LA ESPIGA DE SAN PABLO" FontWeight="Black" FontSize="11" HorizontalAlignment="Center" Foreground="Black"/>
                <TextBlock Text="CALIDAD - SABOR - TRADICIÓN" FontSize="8" HorizontalAlignment="Center" Foreground="Black" FontStyle="Italic" Margin="0,2,0,5"/>
                <TextBlock Text="==========================" FontSize="8" HorizontalAlignment="Center" Foreground="Black"/>

                <!-- INFO VENTA -->
                <TextBlock Text="{Binding SaleDate, StringFormat='{}FECHA: {0:dd/MM/yyyy HH:mm}'}" FontSize="8" Foreground="Black" Margin="0,5,0,0"/>
                <TextBlock Text="{Binding CashierName, StringFormat='{}CAJERO: {0}'}" FontSize="8" Foreground="Black"/>
                <TextBlock Text="{Binding PaymentMethod, StringFormat='{}PAGO: {0}'}" FontSize="8" Foreground="Black"/>
                <TextBlock Text="--------------------------" FontSize="8" HorizontalAlignment="Center" Foreground="Black" Margin="0,5"/>

                <!-- ENCABEZADO ITEMS -->
                <Grid Margin="0,5,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="35"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="DESCRIPCIÓN" FontSize="7.5" FontWeight="Bold" Foreground="Black"/>
                    <TextBlock Grid.Column="1" Text="CANT" FontSize="7.5" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="TOTAL" FontSize="7.5" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Right"/>
                </Grid>

                <!-- LISTA DE PRODUCTOS (ListView Simplificado) -->
                <ListView ItemsSource="{Binding Items}" BorderThickness="0" Background="Transparent" Padding="0">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="35"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding ProductName}" FontSize="8.5" Foreground="Black" TextWrapping="Wrap" VerticalAlignment="Top"/>
                                <TextBlock Grid.Column="1" Text="{Binding Quantity}" FontSize="8.5" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                                <TextBlock Grid.Column="2" Text="{Binding SubTotal, StringFormat=C}" FontSize="8.5" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- TOTAL FINAL -->
                <TextBlock Text="--------------------------" FontSize="8" HorizontalAlignment="Center" Foreground="Black" Margin="0,10,0,5"/>
                <Grid>
                    <TextBlock Text="TOTAL:" FontSize="10" FontWeight="Bold" Foreground="Black" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalAmount, StringFormat=C}" FontSize="15" FontWeight="Black" Foreground="Black" HorizontalAlignment="Right"/>
                </Grid>

                <TextBlock Text="¡GRACIAS POR SU COMPRA!" FontSize="8.5" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                <TextBlock Text="**************************" FontSize="8" HorizontalAlignment="Center" Foreground="Black" Margin="0,2"/>
            </StackPanel>
        </Border>

        <!-- BOTON DE IMPRESION -->
        <Button Grid.Row="2" x:Name="BtnCerrar" Click="Print_Click" Height="45" Margin="0,15,0,0" Background="#1E293B" Foreground="White" BorderThickness="0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🖨️ " VerticalAlignment="Center"/>
                <TextBlock Text="IMPRIMIR Y CERRAR" VerticalAlignment="Center" FontWeight="Bold"/>
            </StackPanel>
        </Button>
    </Grid>
</Window>
