<Window x:Class="BakeryPOS.Views.TicketView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ticket" Width="220" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" Background="White"
        WindowStyle="None" AllowsTransparency="True">
    
    <Border BorderBrush="#EEE" BorderThickness="1" Background="#F3F4F6">
        <StackPanel HorizontalAlignment="Center" Margin="0,10">
            <Border x:Name="TicketBorder" Background="White" Width="200" Padding="10">
                <StackPanel>
                    <!-- Header -->
                    <TextBlock Text="LA ESPIGA DE SAN PABLO" FontWeight="Bold" HorizontalAlignment="Center" Foreground="Black"/>
                    <TextBlock Text="--------------------------------" HorizontalAlignment="Center" Foreground="Black"/>

                    <!-- Encabezado Fijo -->
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="45"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="PRODUCTO" FontSize="8" FontWeight="Bold" Foreground="Black"/>
                        <TextBlock Grid.Column="1" Text="CANT" FontSize="8" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="TOTAL" FontSize="8" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- LISTA DE PRODUCTOS (Uso de ItemsControl simplificado) -->
                    <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#F0F0F0" BorderThickness="0,0,0,1" Padding="0,3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="45"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding ProductName}" FontSize="9" Foreground="Black" TextWrapping="Wrap"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Quantity}" FontSize="9" Foreground="Black" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding SubTotal, StringFormat=C}" FontSize="9" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- TOTAL -->
                    <TextBlock Text="--------------------------------" HorizontalAlignment="Center" Foreground="Black" Margin="0,5"/>
                    <Grid>
                        <TextBlock Text="TOTAL A PAGAR:" FontSize="10" FontWeight="Bold" Foreground="Black"/>
                        <TextBlock Text="{Binding TotalAmount, StringFormat=C}" FontSize="16" FontWeight="Black" Foreground="Black" HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- Info Pie -->
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Text="{Binding SaleDate, StringFormat='{}Fecha: {0:dd/MM/yyyy HH:mm}'}" FontSize="8" Foreground="Gray" HorizontalAlignment="Center"/>
                        <TextBlock Text="¡GRACIAS POR SU COMPRA!" FontSize="9" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Button x:Name="BtnCerrar" Content="IMPRIMIR Y CERRAR" Click="Print_Click" Height="45" Width="180" Margin="0,10,0,0" Background="#111827" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Border>
</Window>
