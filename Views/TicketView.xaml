<Window x:Class="BakeryPOS.Views.TicketView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vista Previa del Ticket" Width="260" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" Background="#F1F5F9"
        WindowStyle="None" AllowsTransparency="True" BorderThickness="1" BorderBrush="#CBD5E1"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    
    <Grid Margin="0"> <!-- Eliminado el margen de 15 -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> 
            <RowDefinition Height="Auto"/> 
            <RowDefinition Height="Auto"/> 
        </Grid.RowDefinitions>

        <TextBlock Text="VISTA PREVIA" FontSize="9" FontWeight="Bold" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,5"/>

        <!-- EL TICKET REAL: Ancho 180px, Padding izquierdo reducido -->
        <Border Grid.Row="1" x:Name="TicketBorder" Background="White" Width="180" Padding="2,5,5,5" CornerRadius="0"
                RenderOptions.BitmapScalingMode="NearestNeighbor"
                RenderOptions.EdgeMode="Aliased">
            <Border.Effect>
                <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.1"/>
            </Border.Effect>
            <StackPanel>
                <!-- CABECERA -->
                <TextBlock Text="LA ESPIGA DE SAN PABLO" FontWeight="Black" FontSize="13" HorizontalAlignment="Center" Foreground="Black"/>
                <TextBlock Text="---------------------------" FontSize="10" HorizontalAlignment="Center" Foreground="Black" Margin="0,2"/>

                <!-- INFO VENTA -->
                <StackPanel HorizontalAlignment="Left" Margin="5,0,0,0">
                    <TextBlock Text="{Binding SaleDate, StringFormat='{}FECHA: {0:dd/MM/yyyy HH:mm}'}" FontSize="10" FontWeight="SemiBold" Foreground="Black"/>
                    <TextBlock Text="{Binding CashierName, StringFormat='{}CAJERO: {0}'}" FontSize="10" FontWeight="SemiBold" Foreground="Black"/>
                </StackPanel>
                <TextBlock Text="---------------------------" FontSize="10" HorizontalAlignment="Center" Foreground="Black" Margin="0,5"/>

                <!-- ENCABEZADO ITEMS -->
                <Grid Margin="2,2,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="55"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="DESC" FontSize="10" FontWeight="Bold" Foreground="Black"/>
                    <TextBlock Grid.Column="1" Text="CANT" FontSize="10" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="TOTAL" FontSize="10" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Right"/>
                </Grid>

                <!-- LISTA DE PRODUCTOS -->
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="55"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding ProductName}" FontSize="11" FontWeight="Medium" Foreground="Black" TextWrapping="Wrap" VerticalAlignment="Top"/>
                                <TextBlock Grid.Column="1" Text="{Binding Quantity}" FontSize="11" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                                <TextBlock Grid.Column="2" Text="{Binding SubTotal, StringFormat=C}" FontSize="11" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- TOTAL FINAL -->
                <TextBlock Text="---------------------------" FontSize="10" HorizontalAlignment="Center" Foreground="Black" Margin="0,8,0,5"/>
                <Grid Margin="2,0,0,0">
                    <TextBlock Text="TOTAL:" FontSize="13" FontWeight="Bold" Foreground="Black" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalAmount, StringFormat=C}" FontSize="19" FontWeight="Black" Foreground="Black" HorizontalAlignment="Right"/>
                </Grid>

                <TextBlock Text="¡GRACIAS POR SU COMPRA!" FontSize="10" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center" Margin="0,15,0,0"/>
            </StackPanel>
        </Border>

        <!-- BOTON DE IMPRESION -->
        <Button Grid.Row="2" x:Name="BtnCerrar" Click="Print_Click" Height="40" Margin="10" Background="#1E293B" Foreground="White" BorderThickness="0">
            <TextBlock Text="IMPRIMIR" FontWeight="Bold"/>
        </Button>
    </Grid>
</Window>
