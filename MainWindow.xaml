<Window x:Class="BakeryPOS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:BakeryPOS.Models"
        Title="La Espiga de San Pablo" Height="768" Width="1280"
        WindowStartupLocation="CenterScreen" Background="{StaticResource BgBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="NavButtonStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="50"/><Setter Property="Foreground" Value="#CBD5E1"/><Setter Property="FontSize" Value="14"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Template">
                <Setter.Value><ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" CornerRadius="8" Background="Transparent" Padding="15,0"><ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/></Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="Background" Value="#334155"/><Setter Property="Foreground" Value="White"/></Trigger>
                            <Trigger Property="IsChecked" Value="True"><Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryBrush}"/><Setter Property="Foreground" Value="White"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate></Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Sidebar Navigation -->
        <Border Grid.Column="0" Background="{StaticResource SecondaryBrush}" Width="260"
                Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <StackPanel Margin="25,40"><TextBlock Text="🥖 LA ESPIGA" FontSize="22" FontWeight="Black" Foreground="White"/><TextBlock Text="PUNTO DE VENTA" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,5,0,0"/></StackPanel>
                <StackPanel Grid.Row="1" Margin="15,0">
                    <RadioButton Content=" Punto de Venta" Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateToPosCommand}" IsChecked="True"/>
                    <RadioButton Content=" Inventario" Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateToProductsCommand}"/>
                    <RadioButton Content=" Producción" Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateToProductionCommand}"/>
                    <RadioButton Content=" Cortes de Caja" Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateToShiftsCommand}"/>
                    <RadioButton Content=" Reportes" Command="{Binding NavigateToReportsCommand}">
                        <RadioButton.Style><Style TargetType="RadioButton" BasedOn="{StaticResource NavButtonStyle}"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding IsAdmin}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></RadioButton.Style>
                    </RadioButton>
                    <RadioButton Content=" Usuarios" Command="{Binding NavigateToUsersCommand}">
                        <RadioButton.Style><Style TargetType="RadioButton" BasedOn="{StaticResource NavButtonStyle}"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding IsAdmin}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></RadioButton.Style>
                    </RadioButton>
                </StackPanel>
                <Border Grid.Row="2" Background="#111827" Padding="20">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="40" Height="40" Background="{StaticResource PrimaryBrush}" CornerRadius="20"><TextBlock Text="👤" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="18"/></Border>
                        <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Source={x:Static models:AppSession.CurrentUser}, Path=Username}" FontWeight="Bold" Foreground="White" FontSize="14"/>
                            <TextBlock Text="{Binding Source={x:Static models:AppSession.CurrentUser}, Path=Role}" Foreground="#94A3B8" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        
        <!-- Main Area -->
        <Grid Grid.Column="1" Margin="30">
            <ContentControl Content="{Binding CurrentView}"/>
        </Grid>
    </Grid>
</Window>
